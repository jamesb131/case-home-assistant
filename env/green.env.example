# CASE core deployment settings for the always-on Green/core role.
# For Home Assistant Green on HA OS, these values should become app/add-on
# options or environment values. Copying this file to .env is for local
# development and future generic Linux Compose hosts.

POSTGRES_USER=case
POSTGRES_PASSWORD=change-this-before-deploying
POSTGRES_DB=case
POSTGRES_HOST=db
POSTGRES_PORT=5432

GOOGLE_CALENDAR_ID=08d8bae9a07144d268a0e3d89f8bb525d49565c664142f4d97fcca1c78dd010f@group.calendar.google.com

# Desktop PC LLM bridge endpoint. CASE should still run if this is offline.
OLLAMA_URL=http://desktop-pc.local:11435/api/chat
OLLAMA_MODEL=llama3.1:8b
OLLAMA_STATUS_TIMEOUT=2
OLLAMA_CHAT_TIMEOUT=60

LOG_INTERVAL=30
WEATHER_POLL_INTERVAL=900
CALENDAR_POLL_INTERVAL=900
BINS_POLL_INTERVAL=3600
STATUS_POLL_INTERVAL=60
RETENTION_INTERVAL=86400
RECURRING_TASK_INTERVAL=3600
RECURRING_TASK_DAYS_AHEAD=21

# Keep pruning disabled until backup and retention expectations are settled.
ENERGY_RETENTION_DAYS=0

CASE_CORS_ORIGINS=http://case.local:8080,http://homeassistant.local:8080
CASE_API_TOKEN=

CASE_WEB_API_BASE_URL=http://case.local:8000
CASE_WEB_API_TOKEN=
