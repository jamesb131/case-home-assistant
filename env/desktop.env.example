# Desktop PC LLM notes.
#
# The core CASE stack does not need to run on the desktop.
# The desktop only needs Ollama reachable from the Green/core device.

OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODEL=llama3.1:8b

# The Green should point to:
# OLLAMA_URL=http://desktop-pc.local:11434/api/chat
#
# Pull the model on the desktop with:
# ollama pull llama3.1:8b
#
# Verify from another device on the LAN with:
# curl http://desktop-pc.local:11434/api/tags
