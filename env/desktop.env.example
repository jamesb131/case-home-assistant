# Desktop PC LLM bridge notes.
#
# The core CASE stack does not need to run on the desktop. The desktop runs
# Ollama plus the optional CASE LLM bridge container.

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_STATUS_TIMEOUT=2
OLLAMA_CHAT_TIMEOUT=60
OLLAMA_KEEP_ALIVE=10m
OLLAMA_WARMUP_INTERVAL=300

# Optional comma-separated IP allow-list for the bridge.
# Start empty while testing. Once stable, set this to the Green IP and any
# trusted admin device that needs direct diagnostics, for example:
# CASE_LLM_ALLOWED_CLIENTS=192.168.0.154,192.168.0.160
CASE_LLM_ALLOWED_CLIENTS=

# The Green should point to:
# OLLAMA_URL=http://desktop-pc.local:11435/api/chat
#
# Pull the model on the desktop with:
# ollama pull llama3.1:8b
#
# Verify from another device on the LAN with:
# curl http://desktop-pc.local:11435/health
# curl http://desktop-pc.local:11435/api/tags
