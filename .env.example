POSTGRES_USER=case
POSTGRES_PASSWORD=changeme
POSTGRES_DB=case
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Local Docker development can use host.docker.internal.
# On the Green, point this at the desktop PC LLM bridge.
# Example: http://desktop-pc.local:11435/api/chat
OLLAMA_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=llama3.1:8b
OLLAMA_STATUS_TIMEOUT=2
OLLAMA_CHAT_TIMEOUT=60

GOOGLE_CALENDAR_ID=08d8bae9a07144d268a0e3d89f8bb525d49565c664142f4d97fcca1c78dd010f@group.calendar.google.com
LOG_INTERVAL=30
WEATHER_POLL_INTERVAL=900
CALENDAR_POLL_INTERVAL=900
BINS_POLL_INTERVAL=3600
STATUS_POLL_INTERVAL=60
RETENTION_INTERVAL=86400
RECURRING_TASK_INTERVAL=3600
RECURRING_TASK_DAYS_AHEAD=21
# Set above 0 to prune raw high-frequency readings after rollups are written.
ENERGY_RETENTION_DAYS=0

CASE_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://case.local:8080

# Optional. Leave unset on trusted local development.
# Set before exposing CASE over VPN/proxy/tunnel.
CASE_API_TOKEN=

# Browser build-time config.
# For LAN deployments, use something like http://case.local:8000.
VITE_API_BASE_URL=http://localhost:8000
VITE_CASE_API_TOKEN=

# Static web container runtime config.
# Leave blank to use the browser hostname with API port 8000.
# Use /api when the web server proxies API requests on the same origin.
CASE_WEB_API_BASE_URL=
CASE_WEB_API_TOKEN=

# Optional Home Assistant-backed IoT integrations.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
ROBOROCK_VACUUM_ENTITY_ID=
# JSON map of voice/UI route names to HA script/button/scene entity IDs.
# Example: {"kitchen":"script.roborock_clean_kitchen"}
ROBOROCK_ROUTE_ENTITIES={}
ROBOROCK_POLL_INTERVAL=60

# ABC News RSS ingestion. Summaries use the local LLM only when available.
NEWS_FEEDS=ABC News|https://www.abc.net.au/news/feed/51120/rss.xml
NEWS_REFRESH_INTERVAL_SECONDS=1800
